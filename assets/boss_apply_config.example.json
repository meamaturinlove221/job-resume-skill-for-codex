{
  "mcp_server": {
    "command": "npx",
    "args": ["-y", "mcp-boss-zp"],
    "env": {}
  },
  "tool_names": {
    "search": "boss_search_jobs",
    "detail": "boss_get_job_detail",
    "apply": "boss_apply_job"
  },
  "search_defaults": {
    "query": "计算机视觉 实习",
    "city": "杭州",
    "limit": 20
  },
  "field_map": {
    "job_id": "job_id",
    "security_id": "security_id",
    "title": "title",
    "company": "company",
    "salary": "salary",
    "city": "city",
    "experience": "experience",
    "education": "education",
    "recruiter": "recruiter",
    "url": "url",
    "description": "description"
  },
  "apply_payload": {
    "resume_id": "",
    "greeting": "您好，我目前两周内可到岗，可实习4个月以上。简历中主要是计算机视觉、三维视觉、Python/C++科研工程相关经历，想投递该岗位，期待进一步沟通。"
  },
  "limits": {
    "max_apply_count": 10,
    "min_interval_seconds": 30
  },
  "safety": {
    "allow_auto_apply": false,
    "require_detail_before_apply": true,
    "dedupe_by_job_key": true,
    "write_audit_log": true
  },
  "paths": {
    "state_file": ".agents/skills/job-resume-codex/.local/boss_apply_state.json",
    "audit_log": ".agents/skills/job-resume-codex/.local/boss_apply_audit.jsonl"
  }
}
